#!/bin/sh
# Spawn a pi agent using Gemma 4 31B via OpenRouter on the host.
# Passes all args through — add -p "prompt" for non-interactive use.
#
# Install: cp scripts/agent-gemma ~/.local/bin/ && chmod +x ~/.local/bin/agent-gemma
OR_KEY=$(cat /home/tcovert/src/claude-openrouter/api-key)
exec env OPENROUTER_API_KEY="$OR_KEY" \
    /home/tcovert/.npm-packages/bin/pi \
    --provider openrouter \
    --model google/gemma-4-31b-it \
    "$@"
